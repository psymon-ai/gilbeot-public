<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon (Android 8.0 / API 26+).

  - background: warm sunset gradient drawable (drawable/ic_launcher_background.xml)
  - foreground: '길' glyph + path accent PNGs (mipmap-*/ic_launcher_foreground.png)

  On older Android (<26) the launcher falls back to the per-density
  legacy PNGs at mipmap-*/ic_launcher.png.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
